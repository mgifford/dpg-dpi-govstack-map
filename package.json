{
  "name": "digital-public-infrastructure-ecosystem-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open source DPI/DPG/GovTech ecosystem atlas with accessible mapping, graph analysis, and monthly automated data refresh.",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:data && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "ingest": "tsx scripts/run-monthly-update.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.1.6",
    "@types/geojson": "^7946.0.16",
    "astro": "^4.16.18",
    "cytoscape": "^3.29.2",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "leaflet": "^1.9.4",
    "lunr": "^2.3.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.15",
    "@types/lunr": "^2.3.7",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
