{
  "name": "digital-public-infrastructure-ecosystem-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open source DPI/DPG/GovTech ecosystem atlas with accessible mapping, graph analysis, and monthly automated data refresh.",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:data && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "ingest": "tsx scripts/run-monthly-update.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "test": "vitest run",
    "audit:axe": "node scripts/audit/axe.mjs",
    "audit:pa11y": "pa11y-ci --config .pa11yci.json",
    "audit:lighthouse": "CHROME_PATH=$(node -e \"console.log(require('playwright').chromium.executablePath())\") lhci autorun --config .lighthouserc.cjs",
    "audit:links": "linkinator http://127.0.0.1:4321/dpg-dpi-govstack-map --recurse --silent --skip '^https?://(?!127\\.0\\.0\\.1:4321)'",
    "audit:site": "start-server-and-test 'npm run preview -- --host 127.0.0.1 --port 4321' http://127.0.0.1:4321/dpg-dpi-govstack-map 'npm run audit:axe && npm run audit:pa11y && npm run audit:lighthouse && npm run audit:links'"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.1.6",
    "@types/geojson": "^7946.0.16",
    "astro": "^6.1.10",
    "cytoscape": "^3.29.2",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "leaflet": "^1.9.4",
    "lunr": "^2.3.9",
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@astrojs/check": "^0.9.9",
    "@types/leaflet": "^1.9.15",
    "@types/lunr": "^2.3.7",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "linkinator": "^6.1.2",
    "pa11y-ci": "^4.1.1",
    "playwright": "^1.52.0",
    "prettier": "^3.3.3",
    "start-server-and-test": "^2.0.8",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
