---
/**
 * AtlasMap — accessible Leaflet map with list-view alternative.
 * Meets WCAG 2.2 AA: keyboard navigation, skip-map, accessible popups,
 * synchronized list, non-color indicators.
 */
export interface MapFeature {
  id: string;
  name: string;
  lat: number;
  lon: number;
  entity_type: "project" | "organization";
  country?: string;
  city?: string;
  popup_label: string;
  popup_detail: string;
}

export interface Props {
  features: MapFeature[];
  height?: string;
}

import "leaflet/dist/leaflet.css";
import { withBase } from "../lib/paths";

const { features, height = "560px" } = Astro.props;
---

<!-- Skip map link — WCAG 2.4.1 -->
<p style="margin-bottom: var(--space-2);">
  <a href="#map-list-view" class="skip-map-link" style="font-size: var(--text-sm);">
    Skip map — go to list view
  </a>
</p>

<!-- Map / List toggle controls -->
<div
  role="tablist"
  aria-label="Map or list view"
  style="display: flex; gap: var(--space-2); margin-bottom: var(--space-4);"
  id="map-view-tabs"
>
  <button
    role="tab"
    id="tab-map"
    aria-selected="true"
    aria-controls="map-panel"
    class="tab"
    type="button"
  >
    Map view
  </button>
  <button
    role="tab"
    id="tab-list"
    aria-selected="false"
    aria-controls="list-panel"
    class="tab"
    type="button"
  >
    List view
  </button>
</div>

<!-- Map panel -->
<div id="map-panel" role="tabpanel" aria-labelledby="tab-map">
  <!-- Instructions for screen reader / keyboard users -->
  <p id="map-instructions" class="sr-only" aria-live="polite">
    Interactive map showing {features.length} locations. Use the list view tab above for a non-visual alternative.
    When focused on a marker, press Enter to open its details.
  </p>
  <div
    id="atlas-map"
    style={`height: ${height};`}
    data-base-url={import.meta.env.BASE_URL}
    role="region"
    aria-label={`Map showing ${features.length} project and organization locations`}
    aria-describedby="map-instructions"
    tabindex="0"
  ></div>
</div>

<!-- List panel (also the no-JS fallback) -->
<div id="list-panel" role="tabpanel" aria-labelledby="tab-list" hidden>
  <section id="map-list-view" tabindex="-1" aria-label="Location list">
    <p style="margin-bottom: var(--space-4); color: var(--color-text-muted); font-size: var(--text-sm);">
      {features.length} locations shown
    </p>
    <ul role="list" style="list-style: none; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-4);">
      {features.map((f) => (
        <li>
          <div class="card" style="padding: var(--space-4);">
            <h3 style="font-size: var(--text-base); margin-bottom: var(--space-1);">{f.name}</h3>
            <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-2);">
              {f.city && `${f.city}, `}{f.country}
            </p>
            <p style="font-size: var(--text-xs);">{f.popup_detail}</p>
            {f.entity_type === "project" && (
              <a href={withBase(`/projects/${f.id}/`)} style="font-size: var(--text-sm);">View project →</a>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
</div>

<script is:inline type="application/json" id="map-data">{JSON.stringify(features)}</script>

<script>
import L from "leaflet";

type RuntimeMapFeature = {
  id: string;
  name: string;
  lat: number;
  lon: number;
  entity_type: "project" | "organization";
  country?: string;
  city?: string;
  popup_label: string;
  popup_detail: string;
};

(function () {
  // Tab panel switching
  const tabMap = document.getElementById("tab-map");
  const tabList = document.getElementById("tab-list");
  const mapPanel = document.getElementById("map-panel");
  const listPanel = document.getElementById("list-panel");

  function showTab(active: "map" | "list") {
    const isMap = active === "map";
    if (!tabMap || !tabList || !mapPanel || !listPanel) return;
    tabMap.setAttribute("aria-selected", String(isMap));
    tabList.setAttribute("aria-selected", String(!isMap));
    mapPanel.hidden = !isMap;
    listPanel.hidden = isMap;
  }

  tabMap?.addEventListener("click", () => showTab("map"));
  tabList?.addEventListener("click", () => showTab("list"));

  // Keyboard arrow-key navigation in tablist
  document.getElementById("map-view-tabs")?.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight" && tabList) { tabList.focus(); showTab("list"); }
    if (e.key === "ArrowLeft" && tabMap)  { tabMap.focus();  showTab("map"); }
  });

  initMap();

  function initMap() {
    const features = JSON.parse(document.getElementById("map-data")?.textContent ?? "[]") as RuntimeMapFeature[];
    const mapEl = document.getElementById("atlas-map");
    if (!mapEl) return;
    const baseUrl = mapEl.getAttribute("data-base-url") ?? "/";

    const map = L.map("atlas-map", {
      center: [20, 0],
      zoom: 2,
      zoomControl: true,
      // Keyboard navigation enabled by default in Leaflet
    });

    // OpenStreetMap tiles (accessible, no API key)
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18
    }).addTo(map);

    // Add markers
    features.forEach((f: RuntimeMapFeature) => {
      if (!f.lat || !f.lon) return;

      const icon = L.divIcon({
        className: "",
        html: `<div style="
          width: 14px; height: 14px;
          background: ${f.entity_type === "organization" ? "#005fcc" : "#166534"};
          border: 2px solid #fff;
          border-radius: 50%;
          box-shadow: 0 1px 3px rgba(0,0,0,.4);
        " role="img" aria-label="${f.name}"></div>`,
        iconSize: [14, 14],
        iconAnchor: [7, 7]
      });

      const marker = L.marker([f.lat, f.lon], {
        icon,
        title: f.name,  // tooltip on hover
        alt: f.name,    // accessible name
        keyboard: true  // keyboard focusable
      });

      // Accessible popup
      const popupContent = `
        <div style="max-width: 220px;">
          <h3 style="margin: 0 0 4px; font-size: 14px;">${f.name}</h3>
          <p style="margin: 0 0 4px; font-size: 12px; color: #666;">${f.popup_label}</p>
          <p style="margin: 0; font-size: 12px;">${f.popup_detail}</p>
          ${f.entity_type === "project" ? `<a href="${baseUrl}projects/${f.id}/" style="font-size:12px;display:block;margin-top:6px;">View project →</a>` : ""}
        </div>
      `;
      marker.bindPopup(popupContent, { maxWidth: 240 });
      marker.addTo(map);
    });

    // Announce zoom changes to screen readers
    const srStatus = document.createElement("div");
    srStatus.setAttribute("aria-live", "polite");
    srStatus.setAttribute("aria-atomic", "true");
    srStatus.className = "sr-only";
    mapEl.appendChild(srStatus);

    map.on("zoomend", () => {
      srStatus.textContent = `Map zoomed to level ${map.getZoom()}`;
    });
  }
})();
</script>
