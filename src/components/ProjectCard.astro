---
/**
 * ProjectCard component
 * Accessible card for project listings with score bars, badges, and proper semantics.
 */
import type { Project } from "../lib/schema";
import { withBase } from "../lib/paths";

export interface Props {
  project: Project;
}

const { project } = Astro.props;

const maturityClass = `badge badge--${project.maturity_level}`;
const typeClass = `badge badge--${project.project_type.toLowerCase()}`;
const footprintCount = project.deployment_countries.length;
const standardsPreview = project.standards_alignment.slice(0, 2);
const govstackPreview = project.govstack_building_blocks.slice(0, 2);
const licenseBadgeClass = `badge badge--license-${project.license_model}`;
---

<article class="card project-card" aria-labelledby={`project-title-${project.id}`}>
  <header>
    <h3 class="project-card__title" id={`project-title-${project.id}`}>
      <a href={withBase(`/projects/${project.id}/`)}>{project.name}</a>
    </h3>
    <div class="project-card__meta">
      <span class={maturityClass}>{project.maturity_level}</span>
      <span class={typeClass}>{project.project_type}</span>
      <span class={licenseBadgeClass}>{project.license_model}</span>
      {project.govstack_listed && (
        <span class="badge badge--govstack-listed">GovStack listed</span>
      )}
      {project.category && (
        <span class="badge" style="background: var(--color-surface); color: var(--color-text-muted); border-color: var(--color-border);">
          {project.category}
        </span>
      )}
    </div>
  </header>

  <p class="project-card__desc">{project.description}</p>

  <div class="project-card__stats" aria-label="Project summary">
    <span><strong>{footprintCount}</strong> known countries</span>
    <span><strong>{project.community_health.contributors_last_12_months}</strong> contributors</span>
    <span><strong>{project.community_health.releases_last_12_months}</strong> releases</span>
  </div>

  <!-- Score bars — accessible with labelled values -->
  <div aria-label="Project scores" style="display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-4);">
    <div class="score-bar">
      <span class="score-bar__label" id={`activity-label-${project.id}`}>Activity</span>
      <div class="score-bar__track" role="progressbar" aria-labelledby={`activity-label-${project.id}`} aria-valuenow={project.activity_score} aria-valuemin={0} aria-valuemax={100}>
        <div class="score-bar__fill" style={`width: ${project.activity_score}%`}></div>
      </div>
      <span class="score-bar__value" aria-hidden="true">{project.activity_score}</span>
    </div>
    <div class="score-bar">
      <span class="score-bar__label" id={`sustain-label-${project.id}`}>Sustain</span>
      <div class="score-bar__track" role="progressbar" aria-labelledby={`sustain-label-${project.id}`} aria-valuenow={project.sustainability_score} aria-valuemin={0} aria-valuemax={100}>
        <div class="score-bar__fill" style={`width: ${project.sustainability_score}%; background: var(--color-success)`}></div>
      </div>
      <span class="score-bar__value" aria-hidden="true">{project.sustainability_score}</span>
    </div>
  </div>

  {standardsPreview.length > 0 && (
    <p class="project-card__standards" aria-label="Standards alignment preview">
      {standardsPreview.join(" · ")}
    </p>
  )}

  {govstackPreview.length > 0 && (
    <p class="project-card__standards" aria-label="GovStack building blocks">
      GovStack: {govstackPreview.join(" · ")}
    </p>
  )}

  {project.licensing_concerns && (
    <p class="project-card__countries" style="color: var(--color-warning);">
      License note: {project.licensing_concerns}
    </p>
  )}

  <!-- Countries -->
  {project.deployment_countries.length > 0 && (
    <p class="project-card__countries">
      <span style="font-weight: 600; color: var(--color-text);">Footprint:</span>{" "}
      {project.deployment_countries.slice(0, 4).join(", ")}
      {project.deployment_countries.length > 4 && ` +${project.deployment_countries.length - 4} more`}
    </p>
  )}

  <!-- Links -->
  <footer style="display: flex; gap: var(--space-3); flex-wrap: wrap;">
    <a
      href={withBase(`/projects/${project.id}/`)}
      aria-label={`View details for ${project.name}`}
      style="font-size: var(--text-sm); font-weight: 600;"
    >
      Details →
    </a>
    {project.website && (
      <a
        href={project.website}
        rel="noopener noreferrer"
        target="_blank"
        aria-label={`${project.name} website (opens in new tab)`}
        style="font-size: var(--text-sm); color: var(--color-text-muted);"
      >
        Website ↗
      </a>
    )}
    {project.repository_urls[0] && (
      <a
        href={project.repository_urls[0]}
        rel="noopener noreferrer"
        target="_blank"
        aria-label={`${project.name} source code (opens in new tab)`}
        style="font-size: var(--text-sm); color: var(--color-text-muted);"
      >
        Source ↗
      </a>
    )}
  </footer>
</article>
