---
import Base from "../../layouts/Base.astro";
---

<Base title="API Documentation" description="Public API for the DPI Ecosystem Atlas — JSON, GeoJSON, and CSV endpoints." currentPage="/api/">
  <div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-16); max-width: 900px;">
    <h1 style="margin-bottom: var(--space-4);">API Documentation</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-10);">
      All endpoints are static files. No authentication required. CORS-enabled. Updated monthly.
    </p>

    <section aria-labelledby="endpoints-heading" style="margin-bottom: var(--space-12);">
      <h2 id="endpoints-heading" style="margin-bottom: var(--space-6);">Endpoints</h2>

      {[
        {
          path: "/api/atlas.json",
          format: "JSON",
          description: "Full dataset — projects, organizations, deployments, relationships, and metadata.",
          schema: "AtlasDataset"
        },
        {
          path: "/api/projects.json",
          format: "JSON",
          description: "All projects with full metadata, community health scores, and deployment countries.",
          schema: "Project[]"
        },
        {
          path: "/api/organizations.json",
          format: "JSON",
          description: "All organizations with coordinates, associated projects, and governance roles.",
          schema: "Organization[]"
        },
        {
          path: "/api/relationships.json",
          format: "JSON",
          description: "All relationships between projects and organizations.",
          schema: "Relationship[]"
        },
        {
          path: "/api/deployments.json",
          format: "JSON",
          description: "All known project deployments with country and status.",
          schema: "Deployment[]"
        },
        {
          path: "/api/map.geojson",
          format: "GeoJSON",
          description: "GeoJSON FeatureCollection of organization locations for map rendering.",
          schema: "GeoJSON FeatureCollection"
        },
        {
          path: "/api/projects.csv",
          format: "CSV",
          description: "Flat CSV of all projects — suitable for spreadsheet analysis.",
          schema: "Tabular"
        },
        {
          path: "/api/graph.json",
          format: "JSON",
          description: "Graph data with nodes and edges for visualization tools.",
          schema: "{ nodes, edges }"
        },
        {
          path: "/api/search-index.json",
          format: "JSON",
          description: "Pre-built Lunr.js search index for client-side full-text search.",
          schema: "Lunr serialized index"
        }
      ].map((ep) => (
        <div class="card" style="padding: var(--space-5); margin-bottom: var(--space-4);">
          <div style="display: flex; align-items: baseline; gap: var(--space-3); flex-wrap: wrap; margin-bottom: var(--space-3);">
            <code style="font-size: var(--text-base); font-family: var(--font-mono); color: var(--color-brand);">{ep.path}</code>
            <span class="badge badge--dpg">{ep.format}</span>
          </div>
          <p style="margin-bottom: var(--space-3); color: var(--color-text-muted);">{ep.description}</p>
          <p style="font-size: var(--text-sm);">Schema: <code>{ep.schema}</code></p>
          <a href={ep.path} style="font-size: var(--text-sm); display: inline-block; margin-top: var(--space-3);">Download →</a>
        </div>
      ))}
    </section>

    <section aria-labelledby="usage-heading" style="margin-bottom: var(--space-12);">
      <h2 id="usage-heading" style="margin-bottom: var(--space-4);">Usage Examples</h2>

      <h3 style="margin-bottom: var(--space-2);">Fetch all projects (JavaScript)</h3>
      <pre style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); overflow-x: auto; font-size: var(--text-sm);"><code>const res = await fetch("https://dpiatlas.example.org/api/projects.json");
const &#123; projects &#125; = await res.json();
console.log(`$&#123;projects.length&#125; projects loaded`);</code></pre>

      <h3 style="margin-top: var(--space-6); margin-bottom: var(--space-2);">Load GeoJSON in MapLibre GL JS</h3>
      <pre style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); overflow-x: auto; font-size: var(--text-sm);"><code>map.addSource("atlas-orgs", &#123;
  type: "geojson",
  data: "https://dpiatlas.example.org/api/map.geojson"
&#125;);</code></pre>

      <h3 style="margin-top: var(--space-6); margin-bottom: var(--space-2);">Download via curl</h3>
      <pre style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); overflow-x: auto; font-size: var(--text-sm);"><code>curl -O https://dpiatlas.example.org/api/projects.csv</code></pre>
    </section>

    <section aria-labelledby="schema-heading">
      <h2 id="schema-heading" style="margin-bottom: var(--space-4);">Schema Reference</h2>
      <p style="color: var(--color-text-muted);">
        Full Zod-validated TypeScript schemas are available in the source repository at
        <a href="https://github.com/mgifford/dpg-dpi-govstack-map/blob/main/src/lib/schema.ts">src/lib/schema.ts</a>.
        See <a href="https://github.com/mgifford/dpg-dpi-govstack-map/blob/main/docs/SCHEMA.md">docs/SCHEMA.md</a> for annotated documentation.
      </p>
    </section>
  </div>
</Base>
