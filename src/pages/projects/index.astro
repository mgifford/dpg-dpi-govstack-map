---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import FilterPanel from "../../components/FilterPanel.astro";
import { readFile } from "node:fs/promises";
import path from "node:path";
import { emptyAtlasDataset, type AtlasDataset } from "../../lib/schema";
import { deriveFilterOptions, type FilterOptions } from "../../lib/filters";

let dataset: AtlasDataset;
try {
  const raw = await readFile(path.resolve("data/processed/atlas.json"), "utf8");
  dataset = JSON.parse(raw) as AtlasDataset;
} catch {
  dataset = emptyAtlasDataset;
}

const projects = dataset.projects;
const filterOptions: FilterOptions = deriveFilterOptions(dataset);
const categoryHighlights = Array.from(
  projects.reduce((acc, project) => {
    const entry = acc.get(project.category) ?? { name: project.category, count: 0 };
    entry.count += 1;
    acc.set(project.category, entry);
    return acc;
  }, new Map<string, { name: string; count: number }>())
)
  .map(([, value]) => value)
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
  .slice(0, 6);

const footprintLeaders = [...projects]
  .sort((a, b) => b.deployment_countries.length - a.deployment_countries.length || b.ecosystem_score - a.ecosystem_score)
  .slice(0, 5);

const govstackHighlights = Array.from(
  projects.reduce((acc, project) => {
    for (const block of project.govstack_building_blocks) {
      acc.set(block, (acc.get(block) ?? 0) + 1);
    }
    return acc;
  }, new Map<string, number>())
)
  .sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0]))
  .slice(0, 6);
---

<Base title="Projects" description="Browse all Digital Public Infrastructure and DPG projects in the atlas." currentPage="/projects/">
  <div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-16);">
    <header style="margin-bottom: var(--space-8);">
      <h1>Projects</h1>
      <p style="color: var(--color-text-muted); margin-top: var(--space-2);">
        {projects.length} projects in the registry. Updated monthly.
      </p>
    </header>

    <section class="catalog-overview" aria-labelledby="catalog-overview-heading">
      <div>
        <h2 id="catalog-overview-heading" style="font-size: var(--text-lg); margin-bottom: var(--space-3);">Catalog Explorer</h2>
        <p style="color: var(--color-text-muted); max-width: 62ch;">
          Search, filter, and now sort the catalog. Quick links below preload the client-side explorer using the URL so collections can be shared.
        </p>
        <div class="catalog-chip-list" style="margin-top: var(--space-4);">
          {categoryHighlights.map((category) => (
            <a class="catalog-chip" href={`?q=${encodeURIComponent(category.name)}`}>{category.name} <span aria-hidden="true">{category.count}</span></a>
          ))}
        </div>
        {govstackHighlights.length > 0 && (
          <div class="catalog-chip-list" style="margin-top: var(--space-3);">
            {govstackHighlights.map(([block, count]) => (
              <a class="catalog-chip" href={`?govstackBlock=${encodeURIComponent(block)}`}>GovStack: {block} <span aria-hidden="true">{count}</span></a>
            ))}
          </div>
        )}
      </div>
      <div class="catalog-overview__side">
        <label for="sort-projects" style="font-size: var(--text-sm); font-weight: 600; margin-bottom: var(--space-2); display: block;">Sort projects</label>
        <select id="sort-projects" name="sort" style="width: 100%; margin-bottom: var(--space-4);">
          <option value="ecosystem-desc">Ecosystem score</option>
          <option value="activity-desc">Activity score</option>
          <option value="deployments-desc">Deployment footprint</option>
          <option value="name-asc">Name</option>
        </select>
        <p style="font-size: var(--text-xs); color: var(--color-text-muted);">
          Leading footprint now: {footprintLeaders.map((project) => project.name).join(", ")}.
        </p>
      </div>
    </section>

    <div class="sidebar-layout">
      <!-- Filter sidebar -->
      <aside aria-label="Project filters" style="position: sticky; top: calc(64px + var(--space-4));">
        <FilterPanel options={filterOptions} totalCount={projects.length} />
      </aside>

      <!-- Project list -->
      <div>
        <!-- Results summary (live region updated by FilterPanel.astro script) -->
        <p class="sr-only" aria-live="polite" aria-atomic="true" id="results-summary">
          Showing {projects.length} projects
        </p>

        <div
          id="project-list"
          class="card-grid"
          aria-label="Project list"
          role="list"
        >
          {projects.map((project) => (
            <div
              role="listitem"
              data-project={project.id}
              data-name={project.name}
              data-desc={project.description}
              data-tags={project.tags.join("|")}
              data-countries={project.deployment_countries.join("|")}
              data-type={project.project_type}
              data-maturity={project.maturity_level}
              data-governance={project.governance_model}
              data-licenses={project.licenses.join("|")}
              data-ecosystem={project.ecosystem_score}
              data-activity={project.activity_score}
              data-deployments={project.deployment_countries.length}
              data-category={project.category}
              data-govstack-blocks={project.govstack_building_blocks.join("|")}
              data-license-model={project.license_model}
            >
              <ProjectCard project={project} />
            </div>
          ))}
        </div>

        <!-- Empty state (shown by JS when no results match) -->
        <div id="no-results" hidden aria-live="polite" style="padding: var(--space-12); text-align: center; color: var(--color-text-muted);">
          <p>No projects match the current filters.</p>
          <p><button id="clear-filters-inline" type="button" style="margin-top: var(--space-4); text-decoration: underline; background: none; border: none; cursor: pointer; color: var(--color-link);">Clear all filters</button></p>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  // Show/hide empty state based on visible cards
  const list = document.getElementById("project-list");
  const noResults = document.getElementById("no-results");
  const clearBtn = document.getElementById("clear-filters-inline");
  const filterReset = document.getElementById("filter-reset") as HTMLButtonElement | null;
  const filterForm = document.getElementById("filter-form") as HTMLFormElement | null;
  const sortSelect = document.getElementById("sort-projects") as HTMLSelectElement | null;
  const filterCount = document.getElementById("filter-count");
  const resultsSummary = document.getElementById("results-summary");

  clearBtn?.addEventListener("click", () => { filterReset?.click(); });

  if (list && noResults) {
    const applySort = () => {
      if (!sortSelect) return;
      const cards = Array.from(list.querySelectorAll<HTMLElement>("[data-project]"));
      const value = sortSelect.value;
      cards.sort((left, right) => {
        if (value === "name-asc") {
          return (left.dataset.name ?? "").localeCompare(right.dataset.name ?? "");
        }
        if (value === "activity-desc") {
          return Number(right.dataset.activity ?? 0) - Number(left.dataset.activity ?? 0);
        }
        if (value === "deployments-desc") {
          return Number(right.dataset.deployments ?? 0) - Number(left.dataset.deployments ?? 0);
        }
        return Number(right.dataset.ecosystem ?? 0) - Number(left.dataset.ecosystem ?? 0);
      });
      cards.forEach((card) => list.append(card));
    };

    const syncUrl = () => {
      if (!filterForm) return;
      const params = new URLSearchParams();
      const formData = new FormData(filterForm);
      for (const [key, rawValue] of formData.entries()) {
        const value = String(rawValue).trim();
        if (!value || value === "all") continue;
        params.set(key, value);
      }
      if (sortSelect && sortSelect.value !== "ecosystem-desc") {
        params.set("sort", sortSelect.value);
      }
      const next = params.toString();
      const url = next ? `${window.location.pathname}?${next}` : window.location.pathname;
      window.history.replaceState({}, "", url);
    };

    const syncResults = () => {
      const visibleCards = list.querySelectorAll("[data-project]:not([hidden])");
      const count = visibleCards.length;
      noResults.hidden = count > 0;
      if (filterCount) {
        filterCount.textContent = `— ${count} project${count !== 1 ? "s" : ""}`;
      }
      if (resultsSummary) {
        resultsSummary.textContent = `Showing ${count} project${count !== 1 ? "s" : ""}`;
      }
    };

    const hydrateFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      if (!filterForm) return;
      for (const [key, value] of params.entries()) {
        const input = filterForm.elements.namedItem(key);
        if (input instanceof HTMLInputElement || input instanceof HTMLSelectElement) {
          input.value = value;
        }
      }
      if (sortSelect && params.get("sort")) {
        sortSelect.value = params.get("sort")!;
      }
    };

    hydrateFromUrl();
    filterForm?.dispatchEvent(new Event("apply-filters"));
    sortSelect?.addEventListener("input", () => {
      applySort();
      syncUrl();
    });
    filterForm?.addEventListener("input", syncUrl);
    filterForm?.addEventListener("change", syncUrl);
    filterForm?.addEventListener("reset", () => {
      setTimeout(syncUrl, 0);
    });

    const observer = new MutationObserver(() => {
      syncResults();
    });
    observer.observe(list, { childList: false, subtree: true, attributes: true, attributeFilter: ["hidden"] });

    requestAnimationFrame(() => {
      applySort();
      syncResults();
      syncUrl();
    });
  }
</script>
