---
import Base from "../layouts/Base.astro";
import { readFile } from "node:fs/promises";
import path from "node:path";
import type { AtlasDataset } from "../lib/schema";
import { withBase } from "../lib/paths";

let dataset: AtlasDataset;
try {
  const raw = await readFile(path.resolve("data/processed/atlas.json"), "utf8");
  dataset = JSON.parse(raw) as AtlasDataset;
} catch {
  dataset = { generated_at: "", version: "0.2.0", sources: [], projects: [], organizations: [], people: [], deployments: [], repositories: [], relationships: [], standards: [] };
}

const projects = [...dataset.projects].sort((a, b) => (b.maturity_scores?.governance.score ?? 0) - (a.maturity_scores?.governance.score ?? 0));
const dimensions = [
  ["code", "Code"],
  ["governance", "Governance"],
  ["stewardship", "Stewardship"],
  ["public_sector", "Public Sector"],
  ["accessibility", "Accessibility"],
  ["sustainability", "Sustainability"],
  ["security", "Security"],
  ["interoperability", "Interoperability"],
  ["procurement", "Procurement"],
  ["community", "Community"],
  ["documentation", "Documentation"]
] as const;
---

<Base title="Compare" description="Accessible comparison tables for maturity, governance, stewardship, and procurement readiness across Atlas projects." currentPage="/compare/">
  <div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-16);">
    <header style="margin-bottom: var(--space-8); max-width: 72ch;">
      <h1>Compare Projects</h1>
      <p style="color: var(--color-text-muted); margin-top: var(--space-2);">
        This comparison view is table-first by design. It emphasizes multi-dimensional maturity rather than popularity,
        and each score dimension includes an explicit rationale on project profile pages.
      </p>
    </header>

    <section aria-labelledby="comparison-summary" style="margin-bottom: var(--space-10);">
      <h2 id="comparison-summary" style="margin-bottom: var(--space-4);">Maturity Overview</h2>
      <p style="margin-bottom: var(--space-6); color: var(--color-text-muted); max-width: 68ch;">
        The matrix below supports keyboard and screen-reader exploration, while the adjacent score bars provide a compact
        visual summary without replacing the underlying table data.
      </p>

      <div style="overflow-x: auto; margin-bottom: var(--space-8);">
        <table class="data-table" aria-describedby="compare-table-description">
          <caption id="compare-table-description" style="caption-side: bottom; text-align: left; padding-top: var(--space-3); color: var(--color-text-muted);">
            Scores range from 0 to 100 and are derived from separate maturity dimensions instead of a single aggregate ranking.
          </caption>
          <thead>
            <tr>
              <th scope="col">Project</th>
              {dimensions.map(([, label]) => <th scope="col">{label}</th>)}
            </tr>
          </thead>
          <tbody>
            {projects.map((project) => (
              <tr>
                <th scope="row"><a href={withBase(`/projects/${project.id}/`)}>{project.name}</a></th>
                {dimensions.map(([key]) => <td>{project.maturity_scores?.[key].score ?? "n/a"}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="card-grid" role="list" aria-label="Accessibility and procurement comparison summaries">
        {projects.map((project) => (
          <article class="card" role="listitem" style="padding: var(--space-5);">
            <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-4);"><a href={withBase(`/projects/${project.id}/`)}>{project.name}</a></h3>
            <div aria-label={`${project.name} comparison bars`} style="display: flex; flex-direction: column; gap: var(--space-3);">
              {[
                ["Accessibility", project.maturity_scores?.accessibility.score ?? project.accessibility_score],
                ["Procurement", project.maturity_scores?.procurement.score ?? 0],
                ["Governance", project.maturity_scores?.governance.score ?? 0],
                ["Stewardship", project.maturity_scores?.stewardship.score ?? 0]
              ].map(([label, value]) => (
                <div class="score-bar">
                  <span class="score-bar__label" style="min-width: 12ch;">{label}</span>
                  <div class="score-bar__track" role="progressbar" aria-label={`${project.name} ${label}: ${value} out of 100`} aria-valuenow={value as number} aria-valuemin={0} aria-valuemax={100}>
                    <div class="score-bar__fill" style={`width: ${value}%;`}></div>
                  </div>
                  <span class="score-bar__value">{value}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</Base>