---
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { readFile } from "node:fs/promises";
import path from "node:path";
import { emptyAtlasDataset, type AtlasDataset } from "../lib/schema";
import { withBase } from "../lib/paths";

// Load dataset at build time
let dataset: AtlasDataset;
try {
  const raw = await readFile(path.resolve("data/processed/atlas.json"), "utf8");
  dataset = JSON.parse(raw) as AtlasDataset;
} catch {
  dataset = emptyAtlasDataset;
}

const featuredProjects = dataset.projects
  .sort((a, b) => b.ecosystem_score - a.ecosystem_score)
  .slice(0, 6);

const stats = {
  projects: dataset.projects.length,
  organizations: dataset.organizations.length,
  countries: new Set(dataset.projects.flatMap((p) => p.deployment_countries)).size,
  relationships: dataset.relationships.length,
};

const categoryCollections = Array.from(
  dataset.projects.reduce((acc, project) => {
    const entry = acc.get(project.category) ?? { name: project.category, count: 0, sampleProjects: [] as string[] };
    entry.count += 1;
    if (entry.sampleProjects.length < 3) {
      entry.sampleProjects.push(project.name);
    }
    acc.set(project.category, entry);
    return acc;
  }, new Map<string, { name: string; count: number; sampleProjects: string[] }>())
)
  .map(([, value]) => value)
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
  .slice(0, 6);

const deploymentLeaders = [...dataset.projects]
  .sort((a, b) => b.deployment_countries.length - a.deployment_countries.length || b.ecosystem_score - a.ecosystem_score)
  .slice(0, 5);
---

<Base title="Home" description="A globally searchable registry and atlas of Digital Public Infrastructure, Digital Public Goods, and GovTech projects." currentPage="/">
  <!-- Hero -->
  <section class="page-hero" aria-labelledby="hero-heading">
    <div class="container">
      <h1 id="hero-heading">Digital Public Infrastructure<br />Ecosystem Atlas</h1>
      <p style="max-width: 640px; margin-top: var(--space-4);">
        A continuously updated, open source registry of DPI, DPG, GovTech, and civic technology projects.
        Search, filter, map, and explore ecosystem relationships.
      </p>
      <div style="display: flex; gap: var(--space-4); flex-wrap: wrap; margin-top: var(--space-8);">
        <a
          href={withBase("/projects/")}
          style="padding: var(--space-3) var(--space-6); background: #fff; color: var(--color-brand-dark); font-weight: 700; border-radius: var(--radius-md); text-decoration: none;"
        >
          Browse Projects
        </a>
        <a
          href={withBase("/map/")}
          style="padding: var(--space-3) var(--space-6); background: rgba(255,255,255,0.15); color: #fff; font-weight: 600; border-radius: var(--radius-md); text-decoration: none; border: 1px solid rgba(255,255,255,0.4);"
        >
          View Map
        </a>
        <a
          href={withBase("/graph/")}
          style="padding: var(--space-3) var(--space-6); background: rgba(255,255,255,0.15); color: #fff; font-weight: 600; border-radius: var(--radius-md); text-decoration: none; border: 1px solid rgba(255,255,255,0.4);"
        >
          Explore Graph
        </a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section aria-labelledby="stats-heading" style="background: var(--color-surface); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <h2 id="stats-heading" class="sr-only">Registry statistics</h2>
      <div class="stats-strip">
        <div class="stat">
          <span class="stat__value">{stats.projects}</span>
          <span class="stat__label">Projects</span>
        </div>
        <div class="stat">
          <span class="stat__value">{stats.organizations}</span>
          <span class="stat__label">Organizations</span>
        </div>
        <div class="stat">
          <span class="stat__value">{stats.countries}</span>
          <span class="stat__label">Countries</span>
        </div>
        <div class="stat">
          <span class="stat__value">{stats.relationships}</span>
          <span class="stat__label">Relationships</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="container" style="padding-top: var(--space-12); padding-bottom: var(--space-12);" aria-labelledby="featured-heading">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-8); flex-wrap: wrap; gap: var(--space-4);">
      <h2 id="featured-heading">Featured Projects</h2>
      <a href={withBase("/projects/")} style="font-size: var(--text-sm); font-weight: 600;">View all {stats.projects} projects →</a>
    </div>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <section class="container" style="padding-bottom: var(--space-12);" aria-labelledby="collections-heading">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-8); gap: var(--space-4); flex-wrap: wrap;">
      <div>
        <h2 id="collections-heading">Ecosystem Collections</h2>
        <p style="color: var(--color-text-muted); margin-top: var(--space-2); max-width: 64ch;">
          Browse the atlas by the strongest clusters already visible in the data. These links land on pre-filtered catalog views.
        </p>
      </div>
      <a href={withBase("/projects/")} style="font-size: var(--text-sm); font-weight: 600;">Open the full catalog →</a>
    </div>
    <div class="collection-grid">
      {categoryCollections.map((collection) => (
        <article class="card collection-card">
          <p class="collection-card__eyebrow">{collection.count} projects</p>
          <h3 style="margin-bottom: var(--space-3);">{collection.name}</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-4);">
            {collection.sampleProjects.join(", ")}
          </p>
          <a href={withBase(`/projects/?q=${encodeURIComponent(collection.name)}`)} style="font-weight: 600;">Explore {collection.name} →</a>
        </article>
      ))}
    </div>
  </section>

  <section style="background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding-block: var(--space-12);" aria-labelledby="leaders-heading">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-8); gap: var(--space-4); flex-wrap: wrap;">
        <div>
          <h2 id="leaders-heading">Deployment Leaders</h2>
          <p style="color: var(--color-text-muted); margin-top: var(--space-2); max-width: 64ch;">
            Projects with the widest known country footprint in the current atlas dataset.
          </p>
        </div>
      </div>
      <div class="leader-list" role="list">
        {deploymentLeaders.map((project) => (
          <article class="card leader-card" role="listitem">
            <p class="collection-card__eyebrow">{project.deployment_countries.length} countries</p>
            <h3 style="margin-bottom: var(--space-2);"><a href={withBase(`/projects/${project.id}/`)}>{project.name}</a></h3>
            <p style="color: var(--color-text-muted); margin-bottom: var(--space-3);">{project.category}</p>
            <p style="font-size: var(--text-sm); color: var(--color-text-muted);">
              {project.deployment_countries.slice(0, 4).join(", ")}
              {project.deployment_countries.length > 4 && ` +${project.deployment_countries.length - 4} more`}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- About the atlas -->
  <section style="background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding-block: var(--space-12);" aria-labelledby="about-heading">
    <div class="container" style="max-width: 860px;">
      <h2 id="about-heading" style="margin-bottom: var(--space-6);">About This Atlas</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-8);">
        <div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-3);">Who it's for</h3>
          <p style="color: var(--color-text-muted);">
            Researchers, governments, NGOs, standards bodies, funders, implementers, procurement teams, and digital ecosystem builders.
          </p>
        </div>
        <div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-3);">What it tracks</h3>
          <p style="color: var(--color-text-muted);">
            DPI, DPG, GovTech, open government technology, civic tech, digital identity, interoperability frameworks, and open standards.
          </p>
        </div>
        <div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-3);">How it works</h3>
          <p style="color: var(--color-text-muted);">
            Data is ingested monthly from the DPG Registry, GovStack, and GitHub. Community health metrics are calculated from open repository data.
          </p>
        </div>
        <div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-3);">Open by design</h3>
          <p style="color: var(--color-text-muted);">
            All data is available as JSON, CSV, and GeoJSON. Source code is MIT licensed.
            <a href={withBase("/api/")}>Browse the API →</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
